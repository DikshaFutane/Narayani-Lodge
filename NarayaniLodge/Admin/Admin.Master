<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Admin.master.cs" Inherits="NarayaniLodge.Admin.Admin" %>

<!DOCTYPE html>

<html>
<head runat="server">
    <title>Admin</title>

    <!-- [Meta] -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- [Favicon] icon -->
    <link rel="icon" href="assets/images/narayanilodgelogo" type="image/x-icon" />

    <!-- [Font] Family -->
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <!-- [phosphor Icons] https://phosphoricons.com/ -->
    <link rel="stylesheet" href="assets/fonts/phosphor/duotone/style.css" />
    <!-- [Tabler Icons] https://tablericons.com -->
    <link rel="stylesheet" href="assets/fonts/tabler-icons.min.css" />
    <!-- [Feather Icons] https://feathericons.com -->
    <link rel="stylesheet" href="assets/fonts/feather.css" />
    <!-- [Font Awesome Icons] https://fontawesome.com/icons -->
    <link rel="stylesheet" href="assets/fonts/fontawesome.css" />
    <!-- [Material Icons] https://fonts.google.com/icons -->
    <link rel="stylesheet" href="assets/fonts/material.css" />
    <!-- [Template CSS Files] -->
    <link rel="stylesheet" href="assets/css/style.css" id="mainstylelink" />

    <!--Sweet Alert Link -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <asp:ContentPlaceHolder ID="head" runat="server">
    </asp:ContentPlaceHolder>
</head>
<body>
    <form id="form1" runat="server">
        <div>

            <!-- [ Pre-loader ] start -->
            <div class="loader-bg fixed inset-0 bg-white dark:bg-themedark-cardbg z-[1034]">
                <div class="loader-track h-[5px] w-full inline-block absolute overflow-hidden top-0">
                    <div class="loader-fill w-[300px] h-[5px] bg-primary-500 absolute top-0 left-0 animate-[hitZak_0.6s_ease-in-out_infinite_alternate]"></div>
                </div>
            </div>
            <!-- [ Pre-loader ] End -->
            <!-- [ Sidebar Menu ] start -->
            <nav class="pc-sidebar">
                <div class="navbar-wrapper">
                    <div class="m-header flex items-center py-2 px-2 mt-2 h-header-height">
                        <a href="Default.aspx" class="b-brand flex items-center gap-3">
                            <!-- ========   Change your logo from here   ============ -->
                            <img src="../img/naraynilogo.png" class="img-fluid logo p-5 ml-4" alt="logo" width="180" height="20" />
                            <img src="../img/naraynilogo.png" class="img-fluid logo logo-sm" />
                        </a>
                    </div>
                    <div class="navbar-content h-[calc(100vh_-_74px)] py-2.5">
                        <ul class="pc-navbar">
                            <li class="pc-item pc-caption">
                                <label>Navigation</label>
                            </li>
                            <li class="pc-item">
                            <li class="pc-item">
                                <a href="Default.aspx" class="pc-link">
                                    <span class="pc-micon">
                                        <i data-feather="home"></i>
                                    </span>
                                    <span class="pc-mtext">Dashboard</span>
                                </a>
                            </li>



                            <li class="pc-item pc-caption">
                                <label>Other</label>
                                <i data-feather="sidebar"></i>
                            </li>
                            <!--Booking-->
                            <li class="pc-item pc-hasmenu">
                                <a href="#!" class="pc-link"><span class="pc-micon"><i data-feather="calendar"></i></span><span
                                    class="pc-mtext">Booking Management</span><span class="pc-arrow"><i class="ti ti-chevron-right"></i></span></a>
                                <ul class="pc-submenu">
                                    <li class="pc-item"><a class="pc-link" href="AllBookings.aspx">All Bookings</a></li>
                                    <li class="pc-item"><a class="pc-link" href="AddBooking.aspx">Add Booking</a></li>
                                    <li class="pc-item"><a class="pc-link" href="PendingBookings.aspx">Pending Bookings</a></li>
                                    <li class="pc-item"><a class="pc-link" href="ConfirmBookings.aspx">Confirm Bookings</a></li>
                                    <li class="pc-item"><a class="pc-link" href="CancelledBookings.aspx">Cancelled Bookings</a></li>
                                </ul>
                            </li>

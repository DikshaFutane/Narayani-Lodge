                            <!--Enquiries-->

                            <li class="pc-item pc-hasmenu">
                                <a href="#!" class="pc-link"><span class="pc-micon"><i data-feather="message-circle"></i></span><span
                                    class="pc-mtext">Enquiries</span><span class="pc-arrow"><i class="ti ti-chevron-right"></i></span></a>
                                <ul class="pc-submenu">
                                    <li class="pc-item"><a class="pc-link" href="enquiries.aspx">Enquiries</a></li>
                                    <%--<li class="pc-item"><a class="pc-link" href="Bookingreq.aspx">Booking Requests</a></li>--%>
                                </ul>
                            </li>

                            <li class="pc-item pc-hasmenu">
                                <a href="#!" class="pc-link"><span class="pc-micon"><i data-feather="users"></i></span><span
                                    class="pc-mtext">User Management</span><span class="pc-arrow"><i class="ti ti-chevron-right"></i></span></a>
                                <ul class="pc-submenu">
                                    <li class="pc-item"><a class="pc-link" href="ViewUsers.aspx">View Users</a></li>
                                    <li class="pc-item"><a class="pc-link" href="BlockedUsers.aspx">Blocked Users</a></li>
                                    <%--<li class="pc-item"><a class="pc-link" href="Bookingreq.aspx">Booking Requests</a></li>--%>
                                </ul>
